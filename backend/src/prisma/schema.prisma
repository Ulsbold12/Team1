generator client {
  provider = "prisma-client-js"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                   String             @id @unique
  name                 String             @default("")
  industry             Industry
  patronage            Subscription
  createdAt            DateTime           @default(now())
  address              String
  description          String
  emailAddress         String
  phoneNumber          String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  members              Client[]
  financeData          Finance[]
  financeAnalyses      FinanceAnalysis[]
  InviteCode           InviteCode[]
  marketingStrategy    MarketingStrategy?
  posts                Post[]
}

model MarketingStrategy {
  id             String       @id @default(cuid())
  orgId          String       @unique
  productName    String
  description    String
  targetAudience String
  advice         String?
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())
  org            Organization @relation(fields: [orgId], references: [id])
}

model Client {
  id         String           @id @unique
  orgId      String?
  role       MemberAccessType
  email      String
  firstname  String
  lastname   String
  profilePic String?
  createdAt  DateTime         @default(now())
  ofOrg      Organization?    @relation(fields: [orgId], references: [id])
  auditLogs  AuditLog[]
}

model Finance {
  id        String       @id @default(cuid())
  orgId     String
  month     DateTime?
  balance   Int?
  revenue   Int?
  expense   Int?
  netProfit Int?
  margin    Int?
  org       Organization @relation(fields: [orgId], references: [id])
}

model FinanceAnalysis {
  id         String       @id @default(cuid())
  orgId      String
  summary    String
  categories Json
  monthly    Json?
  tips       Json
  createdAt  DateTime     @default(now())
  org        Organization @relation(fields: [orgId], references: [id])
}

model Post {
  id          String       @id @default(cuid())
  orgId       String
  title       String
  content     String       @default("")
  platform    String
  reach       Int          @default(0)
  publishedAt DateTime     @default(now())
  published   Boolean      @default(false)
  images      Json         @default("[]")
  org         Organization @relation(fields: [orgId], references: [id])
}

model Administrator {
  id             String   @id @unique
  email          String
  username       String   @unique
  password       String
  createdAt      DateTime @default(now())
  lastAccessTime DateTime @default(now())
}

model InviteCode {
  code         String       @unique
  orgId        String
  createdBy    String
  expiresAt    DateTime
  Organization Organization @relation(fields: [orgId], references: [id])
}

enum Industry {
  TECH
  FINANCE
  HEALTHCARE
  EDUCATION
  RETAIL
  MANUFACTURING
}

enum MemberAccessType {
  EXECUTIVE
  MANAGEMENT
  MEMBER
}

enum Subscription {
  BASIC
  PRO
}

model AuditLog {
  id       String   @id @default(cuid())
  clientId String
  action   String
  target   String
  details  Json?
  date     DateTime @default(now())
  client   Client   @relation(fields: [clientId], references: [id])
}
